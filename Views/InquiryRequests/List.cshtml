@using System.Security.Claims
@using RosATest.Model.Entity
@using RosATest.ViewModels
@model ListInquiryRequestsViewModel


<div class="min-h-screen flex items-center justify-center">
    <div class="container mx-auto p-4">
        <div class="bg-white rounded-lg shadow-lg p-6">
            <div class="flex flex-col">
                <div class="flex flex-row space-x-4 relative">
                    <h2 class="font-bold">Запросы на справки</h2>
                    @if(User.FindFirstValue("GroupCodename") == Group.GroupCodename.Employee.ToString())
                    {
                        <a href="@Url.Action("Create", "InquiryRequests")">Запросить</a>
                    }
                    <form class="absolute top-2 right-2" method="post" action="/User/Logout">
                        @Html.AntiForgeryToken()
                        <input type="submit" value="Выйти" />
                    </form>
                </div>

                <form method="get" asp-controller="InquiryRequests" asp-action="List">
                    @Html.AntiForgeryToken()
                    <div>
                        @Html.LabelFor(m => m.StatusID)
                        @Html.DropDownListFor(
                            m => m.StatusID, 
                            ViewBag.Statuses as IEnumerable<SelectListItem>,
                            "Выберите статус"
                        )
                    </div>

                    <input type="submit" value="Отфильтровать" />
                </form>

                <table>
                    <tr>
                        <th>Сотрудник</th>
                        <th>Тип справки</th>
                        <th>Создана</th>
                        <th>Количество</th>
                        <th>Причина</th>
                        <th>Статус</th>
                        <th>Действия</th>
                    </tr>
                
                    @foreach (var item in ViewBag.Requests)
                    {
                        
                        <tr class="border border-black">
                            <td>@item.User?.Email</td>
                            <td>@item.InquiryType?.Name</td>
                            <td>@item.CreatedAt</td>
                            <td>@item.Count</td>
                            <td>@item.Reason</td>
                            <td>@item.Status?.Name</td>
                            @if(User.FindFirstValue("GroupCodename") == Group.GroupCodename.Accountant.ToString())
                            {
                                <td>
                                    @Html.ActionLink("Изменить", "Update", "InquiryRequests", new { id = item.ID }, null)
                                </td>
                            }
                        </tr>
                        
                    }
                </table>
            </div>
        </div>
    </div>
</div>
